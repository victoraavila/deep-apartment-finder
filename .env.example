# Copy to .env and fill in. Never commit a real .env.

# --- Database --------------------------------------------------------------
# Used by PostgresApartmentRepository and by the docker-compose stack below.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=apartments
POSTGRES_USER=apartments
POSTGRES_PASSWORD=apartments
POSTGRES_DSN=postgresql://apartments:apartments@localhost:5432/apartments

# --- Reasoning LLM (OpenCode Go primary, OpenAI-compatible) ---------------
# OpenCode Go is the daily driver. The provider exposes a curated set of
# models behind the same OpenAI-compatible `/v1/chat/completions` endpoint.
# The base URL defaults to the canonical endpoint
# (`https://opencode.ai/zen/go/v1`) when this is blank, so a key alone is
# enough to run.
#
# Available OpenAI-compatible Go models (Sprint 5):
#   glm-5, glm-5.1, kimi-k2.5, kimi-k2.6, deepseek-v4-pro, deepseek-v4-flash,
#   qwen3.5-plus, qwen3.6-plus, mimo-v2-pro, mimo-v2-omni.
# The MiniMax M2.5 / M2.7 models use the Anthropic protocol and are not
# addressable from the OpenAI-compatible adapter.
OPENCODE_API_KEY=
OPENCODE_BASE_URL=
OPENCODE_MODEL=qwen3.6-plus

# --- Reasoning LLM (Groq fallback) ----------------------------------------
# Groq is the on-demand fallback for when Go is unavailable or rate-limits.
# On the free tier the TPM cap is small (8k for qwen3.6-27b) so this path
# is more useful with a smaller model.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Observability (LangSmith) --------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=deep-apartment-finder

# --- Run behaviour ---------------------------------------------------------
# Maximum listings to ingest per CLI invocation (cap on Fotocasa search).
INGEST_MAX_LISTINGS=50
# Polite delay between HTTP requests to Fotocasa (seconds, float).
SCRAPER_DELAY_SECONDS=1.5
