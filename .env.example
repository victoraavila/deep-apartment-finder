# Copy to .env and fill in. Never commit a real .env.

# --- Database --------------------------------------------------------------
# Used by PostgresApartmentRepository and by the docker-compose stack below.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=apartments
POSTGRES_USER=apartments
POSTGRES_PASSWORD=apartments
POSTGRES_DSN=postgresql://apartments:apartments@localhost:5432/apartments

# --- Reasoning LLM (OpenCode Go primary, OpenAI-compatible) ---------------
# OpenCode Go is the daily driver. The provider exposes a curated set of
# models behind the same OpenAI-compatible `/v1/chat/completions` endpoint.
# The base URL defaults to the canonical endpoint
# (`https://opencode.ai/zen/go/v1`) when this is blank, so a key alone is
# enough to run.
#
# Available OpenAI-compatible Go models (Sprint 5):
#   glm-5, glm-5.1, kimi-k2.5, kimi-k2.6, deepseek-v4-pro, deepseek-v4-flash,
#   qwen3.5-plus, qwen3.6-plus, mimo-v2-pro, mimo-v2-omni.
# The MiniMax M2.5 / M2.7 models use the Anthropic protocol and are not
# addressable from the OpenAI-compatible adapter.
OPENCODE_API_KEY=
OPENCODE_BASE_URL=
OPENCODE_MODEL=qwen3.6-plus

# --- Reasoning LLM (Groq fallback) ----------------------------------------
# Groq is the on-demand fallback for when Go is unavailable or rate-limits.
# On the free tier the TPM cap is small (8k for qwen3.6-27b) so this path
# is more useful with a smaller model.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Observability (LangSmith) --------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=deep-apartment-finder

# --- Run behaviour ---------------------------------------------------------
# Maximum listings to ingest per CLI invocation (cap on Fotocasa search).
INGEST_MAX_LISTINGS=50
# Polite delay between HTTP requests to Fotocasa (seconds, float).
SCRAPER_DELAY_SECONDS=1.5
# Sprint 3 — Idealista polite delay (seconds, float). DataDome-protected;
# keep slightly higher than Fotocasa's. 2.0 matches ADR-011.
IDEALISTA_SCRAPER_DELAY_SECONDS=2.0
# `curl_cffi` impersonation profile for the Idealista scraper. Tested
# profiles that pass DataDome: chrome131, chrome124. Profiles that 403:
# chrome142 and newer.
IDEALISTA_IMPERSONATE=chrome131
# Set to `false` to disable the Idealista scraper entirely (the run
# will only ingest from Fotocasa).
IDEALISTA_ENABLED=true

# --- Researcher web search ------------------------------------------------
# Used only on the first run, when the researcher bootstraps the
# dangerous_neighborhoods constants table.
EXA_API_KEY=

# --- Notification (Gmail SMTP) --------------------------------------------
# Generate the App Password in your Google account security settings
# (https://myaccount.google.com/apppasswords). 2FA must be enabled on
# the account. The password is 16 characters, no spaces.
# GMAIL_SMTP_ADDRESS is the Gmail login that owns the App Password.
# NOTIFY_TO_ADDRESS is the recipient (defaults to GMAIL_SMTP_ADDRESS
# if blank). The CLI refuses to send without these set.
GMAIL_SMTP_ADDRESS=
GMAIL_SMTP_APP_PASSWORD=
NOTIFY_TO_ADDRESS=
# Optional: override host/port for tests or non-Gmail SMTP relays.
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465

# --- Ranking (soft-criteria weights) --------------------------------------
# Final score per apartment = sum(weight_i * score_i) / sum(weight_i).
# Defaults match `SPRINT2.md`. Tune here, not in code.
RANK_WEIGHT_DISTANCE=0.5
RANK_WEIGHT_PET_POLICY=0.3
RANK_WEIGHT_FURNISHED=0.2
# Distance at which the distance-to-dangerous criterion saturates at 1.0.
RANK_MAX_DISTANCE_M=2000.0
# Top-N apartments the notifier emails per day.
RANK_TOP_N=5
